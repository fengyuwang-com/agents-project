# ============================================================
# .gitignore — 通用项目模板
# ============================================================
#
# 🔑 核心原则（两条铁律）：
#
#   【开源项目】严禁任何私有信息入库。
#       密钥、密码、Token、个人配置 → 死也不能传。
#       目标是：随便一个人 clone 下来就能跑，但拿不到你的任何秘密。
#
#   【私有项目】为传输方便尽量全传，仅排除缓存和编译垃圾。
#       宁可多传一个配置文件，也别让同事 clone 下来跑不起来。
#       唯一红线：node_modules、build、.cache 等纯垃圾。
#
# 🔧 切换指南：
#       如果你在用本文件作为开源项目 → 直接用，不用改。
#       如果你在用本文件作为私有项目 → 删掉下面标记了「🔒开源必排」的整段。
# ============================================================


# ============================================================
# 🔒 开源必排：凭证与密钥
#    私有项目如果团队内都可信，可以整段删掉或取消注释
# ============================================================
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.truststore
secrets.yaml
secrets.yml
credentials.json
service-account.json
*.secret
.env
.env.*
!.env.example
**/private/
**/secrets/


# ============================================================
# 💻 操作系统杂文件（一律排除，跟场景无关）
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/


# ============================================================
# 💻 IDE 与编辑器（个人偏好，一律排除）
# ============================================================
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project


# ============================================================
# 🗑 编译与构建产物（一律排除，纯垃圾）
# ============================================================
build/
dist/
out/
target/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.dylib
*.pyc
*.pyo
__pycache__/
*.egg-info/
eggs/
.eggs/
*.tsbuildinfo


# ============================================================
# 🗑 包管理器缓存（一律排除，npm install 就有了）
# ============================================================
node_modules/
.pnp/
.pnp.js
bower_components/
vendor/
packages/


# ============================================================
# 🗑 日志与临时文件（一律排除，纯垃圾）
# ============================================================
*.log
*.tmp
*.temp
*.cache
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*


# ============================================================
# 🗑 测试与覆盖率（一律排除）
# ============================================================
coverage/
*.lcov
.nyc_output/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
.hypothesis/


# ============================================================
# 🗑 数据库文件（一律排除，含敏感数据）
# ============================================================
*.sqlite
*.sqlite3
*.db
*.mdb


# ============================================================
# 📦 Docker（Dockerfile 本身要传，但 compose override 不传）
# ============================================================
docker-compose.override.yml


# ============================================================
# 🔒 开源必排：压缩包
#    私有项目如需传压缩包给同事，注释掉下面这 4 行
# ============================================================
*.zip
*.tar.gz
*.rar
*.7z


# ============================================================
# 🔒 开源必排：本地配置覆盖文件
#    私有项目如需传本地配置，注释掉下面这 3 行
# ============================================================
.local/
*.local
local.*


# ============================================================
# 📋 极端保守规则（默认关闭，按需开启）
# ============================================================
# .terraform/
# *.bak
# *.orig
